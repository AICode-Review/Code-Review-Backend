# Supabase
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=
# Postgres connection string (pg-boss + migrations). For local supabase:
# postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=

# LLM providers — required for the review engine to actually run.
# ANTHROPIC_API_KEY: logic/security/contracts/concurrency/errors/tests/style passes + rulebook compiler.
# OPENAI_API_KEY: cross-examination verification (the skeptic).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# GitHub App (create via github-app-manifest.json)
GITHUB_APP_ID=
# PEM contents. Either paste with literal \n for newlines, or base64-encode the whole PEM.
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Bitbucket PR review automation — optional. Without this, GET /api/bitbucket/connect's
# adapter throws (Bitbucket *sign-in* via Supabase Auth works regardless).
# One app-wide secret used for every workspace webhook we register (Bitbucket Cloud's
# "secure webhooks" HMAC-SHA256 X-Hub-Signature, same scheme as GitHub's). Per-workspace
# API auth is a customer-supplied Workspace Access Token, connected via
# POST /api/bitbucket/connect and cached encrypted (needs ENCRYPTION_KEY) — no OAuth flow.
BITBUCKET_WEBHOOK_SECRET=

# Publicly reachable URL for this backend — only needed to serve the Atlassian Connect
# app descriptor (GET /bitbucket/atlassian-connect.json) once you register this app as
# an Atlassian Marketplace vendor. Unset in the meantime; the manual-token flow above
# doesn't need it.
BACKEND_PUBLIC_URL=

# Razorpay — optional. Without RAZORPAY_KEY_ID/RAZORPAY_KEY_SECRET, billing
# checkout/cancel/change-plan return 501 and the webhook is a no-op. Plan ids are
# created in the Razorpay dashboard (Subscriptions -> Plans) and needed only for
# checkout/change-plan (webhook sync works without them, aside from tier resolution).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_PRO=
RAZORPAY_PLAN_TEAM=

# Email via SMTP (invites + review-complete notifications to the org owner) — optional.
# Without SMTP_HOST/SMTP_USER/SMTP_PASS + FRONTEND_URL all set, invite creation still
# works exactly as before (the web app shows a copyable link), and review-complete
# emails are simply skipped — neither ever blocks the thing it's attached to. Works with
# any standard SMTP server/relay (Gmail Workspace, Office365, Amazon SES, Mailgun, etc).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# true = implicit TLS (typically port 465); false (default) = STARTTLS (typically port 587).
SMTP_SECURE=false
EMAIL_FROM=CodeFerret <onboarding@codeferret.dev>
# Origin of the deployed web app — builds the /invite/:token and /runs/:id links used in emails.
FRONTEND_URL=https://app.codeferret.dev

# Comma-separated emails auto-granted platform admin console access on next sign-in —
# see CLAUDE.md's admin console section. Unset means no one is auto-promoted.
ADMIN_BOOTSTRAP_EMAILS=

# 32 bytes hex — for encrypting platform tokens at rest
ENCRYPTION_KEY=

# CORS allowlist for the REST API in production (comma-separated). Ignored in development (all origins allowed).
CORS_ORIGIN=https://app.codeferret.dev

PORT=4000
RUN_COST_CAP_USD=0.60
MODEL_FRONTIER=claude-sonnet-5
MODEL_MID=claude-haiku-4-5
MODEL_SKEPTIC=gpt-5
MODEL_EMBED=text-embedding-3-small
